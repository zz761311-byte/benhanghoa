---
export const prerender = false;   // SSR: render tại chỗ trên Cloudflare mỗi lần truy cập

import Layout from "../layouts/Layout.astro";
import LeadCTA from "../components/LeadCTA.astro";

// ── Lấy news.json LIVE mỗi lần truy cập (SSR) → Google + người dùng luôn thấy tin
// mới nhất mà KHÔNG cần build lại web. Thử GitHub (tươi nhất) trước, lỗi thì lấy
// bản tĩnh kèm trong build. Cloudflare Functions KHÔNG có node:fs → dùng fetch.
const CAT_LABEL = { metal: "Kim loại", energy: "Năng lượng", agri: "Nông sản", soft: "Nguyên liệu", macro: "Vĩ mô" };
const CAT_ICON = { metal: "🪙", energy: "🛢️", agri: "🌾", soft: "☕", macro: "🌐" };
const catLabel = (c) => CAT_LABEL[c] || "Hàng hóa";
const catIcon = (c) => CAT_ICON[c] || "📦";
const catKey = (c) => (CAT_ICON[c] ? c : "macro");
const readHref = (n) => "/tin-tuc/doc/?id=" + (n.id || "");
const fmtDate = (s) => {
  const d = new Date(String(s || "").replace(" ", "T"));
  if (isNaN(d.getTime())) return "";
  const p = (x) => String(x).padStart(2, "0");
  return `${p(d.getDate())}/${p(d.getMonth() + 1)}/${d.getFullYear()}`;
};

const REMOTE = "https://raw.githubusercontent.com/zz761311-byte/benhanghoa/main/public/data/news.json";
const LOCAL = new URL("/data/news.json", Astro.url).href;
let raw = { items: [], updated_at: "" };
for (const url of [REMOTE, LOCAL]) {
  try { const r = await fetch(url, { cache: "no-store" }); if (r.ok) { raw = await r.json(); break; } } catch (e) {}
}
const updatedAt = raw.updated_at || "";
const ts = (x) => new Date(String(x.published || "").replace(" ", "T")).getTime() || 0;
const items = (raw.items || []).slice().sort((a, b) => ts(b) - ts(a));

const cats = ["all", ...new Set(items.map((i) => i.category).filter(Boolean))];
const featured = items[0];
const rest = items.slice(1);

// Cache ở biên Cloudflare 5 phút: đỡ gọi GitHub liên tục + tải nhanh, vẫn đủ tươi.
Astro.response.headers.set("Cache-Control", "public, max-age=0, s-maxage=300");
---
<Layout page="news" title="Tin tức hàng hóa — Bến Hàng Hóa" description="Tin tức thế giới ảnh hưởng đến giá hàng hóa, dịch sang tiếng Việt.">
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h1>📰 Tin tức hàng hóa</h1>
        <span id="news-updated" style="color:var(--muted);font-size:13px">{updatedAt ? "Cập nhật lúc: " + updatedAt : ""}</span>
      </div>
      <div id="news-filter" class="cta" style="margin-bottom:18px;flex-wrap:wrap">
        {cats.map((c, i) => (
          <button class={`btn ${i === 0 ? "btn-primary" : "btn-ghost"}`} data-cat={c}>{c === "all" ? "Tất cả" : catLabel(c)}</button>
        ))}
      </div>
      <div id="news-list" class="news-list">
        {featured ? (
          <Fragment>
            <article class="news-feat">
              <a class={`news-feat-thumb thumb-${catKey(featured.category)}`} href={readHref(featured)} aria-label={featured.title_vi || featured.title}>
                <span class="news-feat-icon">{catIcon(featured.category)}</span>
                {featured.image && <img class="news-feat-img" src={featured.image} alt="" loading="lazy" onerror="this.remove()" />}
              </a>
              <div class="news-feat-body">
                <span class={`tag ${featured.category || ""}`}>{catLabel(featured.category)}</span>
                <h3><a href={readHref(featured)}>{featured.title_vi || featured.title}</a></h3>
                {featured.summary_vi && <p class="news-summary">{featured.summary_vi}</p>}
                <div class="news-meta">
                  <span>{featured.source || ""}</span>
                  <span class="news-time">🕒 {fmtDate(featured.published)}</span>
                </div>
              </div>
            </article>
            {rest.length > 0 && (
              <div class="news-grid">
                {rest.map((n) => (
                  <article class="news-card">
                    <a class={`news-card-thumb thumb-${catKey(n.category)}`} href={readHref(n)} aria-label={n.title_vi || n.title}>
                      <span class="news-card-icon">{catIcon(n.category)}</span>
                      {n.image && <img class="news-card-img" src={n.image} alt="" loading="lazy" onerror="this.remove()" />}
                    </a>
                    <div class="news-card-body">
                      <span class={`tag ${n.category || ""}`}>{catLabel(n.category)}</span>
                      <h3><a href={readHref(n)}>{n.title_vi || n.title}</a></h3>
                      {n.summary_vi && <p class="news-summary clamp-2">{n.summary_vi}</p>}
                      <div class="news-meta">
                        <span>{n.source || ""}</span>
                        <span class="news-time">🕒 {fmtDate(n.published)}</span>
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            )}
          </Fragment>
        ) : (
          <div class="empty-note">⏳ Đang tải tin tức…</div>
        )}
      </div>
    </div>
  </section>

  <div class="container" id="dang-ky" style="scroll-margin-top:84px">
    <LeadCTA item="hàng hóa" />
  </div>
</Layout>

<script>
  const CAT_LABEL = {
    metal: "Kim loại", energy: "Năng lượng",
    agri: "Nông sản", soft: "Nguyên liệu", macro: "Vĩ mô"
  };
  // Biểu tượng theo nhóm hàng — dùng thay ảnh (tin không kèm ảnh), tạo điểm nhìn.
  const CAT_ICON = {
    metal: "🪙", energy: "🛢️", agri: "🌾", soft: "☕", macro: "🌐"
  };
  const catLabel = (c) => CAT_LABEL[c] || "Hàng hóa";
  const catIcon = (c) => CAT_ICON[c] || "📦";
  const catKey = (c) => (CAT_ICON[c] ? c : "macro");
  // PHẢI khớp y hệt makeId trong scripts/fetch-news.mjs (để link tới trang đọc nội bộ)
  function makeId(s) {
    s = String(s || "");
    let h = 5381;
    for (let i = 0; i < s.length; i++) h = (((h << 5) + h) ^ s.charCodeAt(i)) >>> 0;
    return h.toString(36);
  }
  const idOf = (n) => n.id || makeId(n.link || n.title);
  const readHref = (n) => "/tin-tuc/doc/?id=" + idOf(n);
  // Chống XSS: escape mọi dữ liệu từ tin (tiêu đề/tóm tắt từ nguồn ngoài qua máy dịch)
  const esc = (s) => String(s || "").replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
  function fmtWhen(s) {
    if (!s) return "";
    const d = new Date(String(s).replace(" ", "T"));
    if (isNaN(d)) return s;
    const diff = (Date.now() - d.getTime()) / 1000;
    const p = (n) => String(n).padStart(2, "0");
    const abs = `${p(d.getDate())}/${p(d.getMonth() + 1)} ${p(d.getHours())}:${p(d.getMinutes())}`;
    let rel = "";
    if (diff < 60) rel = "vừa xong";
    else if (diff < 3600) rel = Math.floor(diff / 60) + " phút trước";
    else if (diff < 86400) rel = Math.floor(diff / 3600) + " giờ trước";
    else if (diff < 7 * 86400) rel = Math.floor(diff / 86400) + " ngày trước";
    return rel ? `${abs} · ${rel}` : abs;
  }
  const tsOf = (n) => new Date(String(n.published || "").replace(" ", "T")).getTime() || 0;
  // Đọc tin: thử GitHub (tươi nhất) trước, lỗi thì quay về bản tĩnh trong build
  async function loadNewsData() {
    const REMOTE = "https://raw.githubusercontent.com/zz761311-byte/benhanghoa/main/public/data/news.json";
    const LOCAL = "/data/news.json";
    for (const url of [REMOTE, LOCAL]) {
      try { const r = await fetch(url, { cache: "no-store" }); if (r.ok) return await r.json(); } catch (e) {}
    }
    return null;
  }
  const listEl = document.getElementById("news-list");
  const filterEl = document.getElementById("news-filter");
  const updatedEl = document.getElementById("news-updated");
  let allItems = [];
  let current = "all";

  // Tin nổi bật (lớn, đầu trang)
  function featuredCard(n) {
    return `
      <article class="news-feat">
        <a class="news-feat-thumb thumb-${catKey(n.category)}" href="${readHref(n)}" aria-label="${esc(n.title_vi || n.title)}">
          <span class="news-feat-icon">${catIcon(n.category)}</span>
          ${n.image ? `<img class="news-feat-img" src="${esc(n.image)}" alt="" loading="lazy" onerror="this.remove()">` : ""}
        </a>
        <div class="news-feat-body">
          <span class="tag ${esc(n.category || "")}">${catLabel(n.category)}</span>
          <h3><a href="${readHref(n)}">${esc(n.title_vi || n.title)}</a></h3>
          ${n.summary_vi ? `<p class="news-summary">${esc(n.summary_vi)}</p>` : ""}
          <div class="news-meta">
            <span>${esc(n.source || "")}</span>
            <span class="news-time">🕒 ${fmtWhen(n.published)}</span>
          </div>
        </div>
      </article>`;
  }
  // Thẻ tin nhỏ (lưới 2 cột)
  function smallCard(n) {
    return `
      <article class="news-card">
        <a class="news-card-thumb thumb-${catKey(n.category)}" href="${readHref(n)}" aria-label="${esc(n.title_vi || n.title)}">
          <span class="news-card-icon">${catIcon(n.category)}</span>
          ${n.image ? `<img class="news-card-img" src="${esc(n.image)}" alt="" loading="lazy" onerror="this.remove()">` : ""}
        </a>
        <div class="news-card-body">
          <span class="tag ${esc(n.category || "")}">${catLabel(n.category)}</span>
          <h3><a href="${readHref(n)}">${esc(n.title_vi || n.title)}</a></h3>
          ${n.summary_vi ? `<p class="news-summary clamp-2">${esc(n.summary_vi)}</p>` : ""}
          <div class="news-meta">
            <span>${esc(n.source || "")}</span>
            <span class="news-time">🕒 ${fmtWhen(n.published)}</span>
          </div>
        </div>
      </article>`;
  }

  function render() {
    const items = current === "all" ? allItems : allItems.filter((i) => i.category === current);
    if (!items.length) { listEl.innerHTML = '<div class="empty-note">Chưa có tin trong mục này.</div>'; return; }
    const [first, ...rest] = items;
    listEl.innerHTML =
      featuredCard(first) +
      (rest.length ? `<div class="news-grid">${rest.map(smallCard).join("")}</div>` : "");
  }

  function buildFilters() {
    const cats = ["all", ...new Set(allItems.map((i) => i.category).filter(Boolean))];
    filterEl.innerHTML = cats.map((c) => {
      const label = c === "all" ? "Tất cả" : (CAT_LABEL[c] || c);
      return `<button class="btn btn-ghost" data-cat="${c}">${label}</button>`;
    }).join("");
    filterEl.querySelectorAll("button").forEach((b) => {
      b.addEventListener("click", () => {
        current = b.dataset.cat;
        filterEl.querySelectorAll("button").forEach((x) => x.classList.remove("btn-primary"));
        b.classList.add("btn-primary");
        render();
      });
    });
    const first = filterEl.querySelector('button[data-cat="all"]');
    if (first) first.classList.add("btn-primary");
  }

  loadNewsData()
    .then((d) => {
      if (!d) return;   // giữ nguyên bản tĩnh đã render sẵn nếu không tải được live
      allItems = (d.items || []).slice().sort((a, b) => tsOf(b) - tsOf(a));
      if (!allItems.length) return;
      if (updatedEl && d.updated_at) updatedEl.textContent = "Cập nhật lúc: " + d.updated_at;
      buildFilters();
      render();
    })
    .catch(() => {});
</script>
