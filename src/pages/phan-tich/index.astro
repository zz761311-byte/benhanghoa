---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const CAT = { metal: "Kim loại", energy: "Năng lượng", agri: "Nông sản", soft: "Nguyên liệu", macro: "Vĩ mô" };
---
<Layout page="analysis" title="Phân tích & Bài viết — Bến Hàng Hóa" description="Phân tích, nhận định thị trường hàng hóa từ Bến Hàng Hóa.">
  <section class="section">
    <div class="container">
      <div class="section-head"><h2>📝 Phân tích & Bài viết</h2></div>
      <div class="news-list">
        {posts.map((p) => (
          <article class="news-item">
            <h3><a href={`/phan-tich/${p.slug}`}>{p.data.title}</a></h3>
            <div class="news-meta">
              <span class="tag {p.data.category}">{CAT[p.data.category] || "Bài viết"}</span>
              <span>{p.data.date.toLocaleDateString("vi-VN")}</span>
            </div>
            {p.data.summary && <p class="news-summary">{p.data.summary}</p>}
          </article>
        ))}
        {posts.length === 0 && <div class="empty-note">Chưa có bài viết.</div>}
      </div>
    </div>
  </section>
</Layout>
