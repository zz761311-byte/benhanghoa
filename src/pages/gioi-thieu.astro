---
import Layout from "../layouts/Layout.astro";
import Trust from "../components/Trust.astro";
import LeadCTA from "../components/LeadCTA.astro";

// 4 nhóm hàng theo dõi — icon + màu khớp với trang Tin tức.
const cats = [
  { icon: "🛢️", key: "energy", name: "Năng lượng", items: "Dầu WTI, Dầu Brent, Khí tự nhiên, Xăng RBOB" },
  { icon: "🌾", key: "agri",   name: "Nông sản",    items: "Ngô, Đậu tương, Khô đậu, Dầu đậu, Lúa mì" },
  { icon: "☕", key: "soft",   name: "Nguyên liệu CN", items: "Cà phê (Arabica/Robusta), Đường, Cacao, Bông, Cao su" },
  { icon: "🪙", key: "metal",  name: "Kim loại",    items: "Vàng, Bạc, Đồng, Bạch kim, Quặng sắt, Nhôm, Kẽm, Chì, Niken, Thiếc" },
];
---
<Layout page="about" title="Giới thiệu — Bến Hàng Hóa" description="Về Bến Hàng Hóa — nơi người Việt theo dõi giá hàng hóa thế giới, tin tức dịch tiếng Việt và tư vấn giao dịch qua Sở MXV.">

  <section class="section">
    <div class="container" style="max-width:1000px">
      <!-- Hero giới thiệu -->
      <div class="about-hero">
        <img class="about-badge" src="/assets/img/logo-badge.png" alt="Bến Hàng Hóa — Nơi trader cập bến" />
        <div class="about-intro">
          <div class="hero-kicker">⚓ Nơi trader cập bến</div>
          <h1>Về Bến Hàng Hóa</h1>
          <p>
            <strong>Bến Hàng Hóa</strong> là nơi người Việt theo dõi nhanh giá các loại hàng hóa
            giao dịch trên sàn quốc tế, cập nhật tin tức thế giới ảnh hưởng đến giá —
            <strong>tất cả bằng tiếng Việt</strong> — và được đồng hành tư vấn giao dịch qua
            Sở Giao dịch Hàng hóa Việt Nam (MXV).
          </p>
          <div class="cta">
            <a class="btn btn-primary" href="#lien-he">📈 Nhận tư vấn miễn phí</a>
            <a class="btn btn-ghost" href="/bang-gia">📊 Xem bảng giá</a>
          </div>
        </div>
      </div>

      <!-- Phạm vi theo dõi -->
      <div class="section-head" style="margin-top:42px"><h2>Phạm vi theo dõi</h2></div>
      <div class="cat-grid">
        {cats.map((c) => (
          <div class="cat-card">
            <span class={`cat-ic thumb-${c.key}`}>{c.icon}</span>
            <div class="cat-text">
              <h3>{c.name}</h3>
              <p>{c.items}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Vì sao chọn Bến Hàng Hóa (tái dùng khối niềm tin) -->
  <section class="section">
    <div class="container"><Trust /></div>
  </section>

  <!-- Sứ mệnh -->
  <section class="section">
    <div class="container" style="max-width:1000px">
      <div class="mission">
        <span class="mission-icon">🎯</span>
        <div>
          <h2>Sứ mệnh của chúng tôi</h2>
          <p>
            Giúp nhà đầu tư Việt tiếp cận thị trường hàng hóa thế giới một cách
            <strong>dễ hiểu, minh bạch và tận tâm</strong>: thông tin giá &amp; tin tức rõ ràng
            bằng tiếng Việt, kiến thức nền tảng bài bản, và đội ngũ tư vấn đồng hành ở mỗi bước.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Form tư vấn -->
  <div class="container" id="lien-he" style="scroll-margin-top:84px">
    <LeadCTA item="hàng hóa" />
  </div>

  <!-- Ghi chú -->
  <section class="section">
    <div class="container" style="max-width:1000px">
      <div class="notice">
        <b>Lưu ý:</b> Giá hiển thị lấy từ TradingView, chỉ mang tính <b>tham khảo</b>,
        không phải lời khuyên đầu tư.
      </div>
    </div>
  </section>

</Layout>
