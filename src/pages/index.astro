---
import Layout from "../layouts/Layout.astro";
import LeadCTA from "../components/LeadCTA.astro";
import Trust from "../components/Trust.astro";
import { TICKER, ALL } from "../data/commodities.mjs";

// Mã nổi bật → kèm slug trang chi tiết, để bấm vào ô đi tới trang NỘI BỘ
// của mình (không nhảy sang TradingView như mặc định của widget).
const featured = [
  "OANDA:XAUUSD",       // Vàng
  "OANDA:XAGUSD",       // Bạc
  "OANDA:XPTUSD",       // Bạch kim
  "OANDA:XCUUSD",       // Đồng
  "CAPITALCOM:COFFEE",  // Cà phê (Arabica)
  "CAPITALCOM:SOYBEAN", // Đậu tương
  "CAPITALCOM:COTTON",  // Bông
  "CAPITALCOM:CORN"     // Ngô
].map((sym) => {
  const it = ALL.find((x) => x.tv === sym);
  return { sym, slug: it ? it.slug : "", name: it ? it.name : "" };
});
---
<Layout page="home">
  <div class="ticker-host">
    <div id="ticker" class="tradingview-widget-container"></div>
    <a class="ticker-link" href="/bang-gia" aria-label="Xem bảng giá"></a>
  </div>

  <section class="hero-showcase">
    <div class="container">
      <img class="hero-img" src="/assets/img/hero-banner.jpg" alt="Bến Hàng Hóa — cảng hàng hóa thế giới" />
      <div class="hero-copy">
        <div class="hero-kicker">⚓ Nơi trader cập bến</div>
        <h1>Hàng hóa thế giới — giá, tin tức &amp; <span class="hl">cơ hội cho người Việt</span></h1>
        <p>Cập nhật giá năng lượng, nông sản, kim loại real-time; tin tức quốc tế dịch sang tiếng Việt; đồng hành tư vấn giao dịch tận tâm cùng bạn.</p>
        <div class="cta">
          <a class="btn btn-primary btn-lg" href="#dang-ky">📈 Mở tài khoản / Nhận tư vấn</a>
          <a class="btn btn-ghost" href="/bang-gia">📊 Xem bảng giá</a>
          <a class="btn btn-ghost" href="/tin-tuc">📰 Đọc tin tức</a>
        </div>
        <p class="hero-note">✓ Tư vấn miễn phí · không ràng buộc · giao dịch qua Sở Giao dịch Hàng hóa VN (MXV)</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>Hàng hóa nổi bật</h2>
        <a href="/bang-gia">Xem tất cả →</a>
      </div>
      <div id="featured-grid" class="grid cols-4"></div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>Tin mới nhất</h2>
        <a href="/tin-tuc">Xem thêm →</a>
      </div>
      <div id="home-news" class="news-grid"></div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <Trust />
    </div>
  </section>

  <div class="container" id="dang-ky" style="scroll-margin-top:84px">
    <LeadCTA item="hàng hóa" />
  </div>
</Layout>

<script define:vars={{ TICKER, featured }}>
  // Thanh ticker
  const tickerHost = document.getElementById("ticker");
  if (tickerHost) {
    const s = document.createElement("script");
    s.async = true;
    s.src = "https://s3.tradingview.com/external-embedding/embed-widget-ticker-tape.js";
    s.innerHTML = JSON.stringify({
      symbols: TICKER, showSymbolLogo: true, isTransparent: true,
      displayMode: "adaptive", colorTheme: "dark", locale: "vi_VN"
    });
    tickerHost.appendChild(s);
  }

  // Hàng hóa nổi bật (mini chart)
  const grid = document.getElementById("featured-grid");
  if (grid) {
    featured.forEach((f) => {
      const card = document.createElement("div");
      card.className = "card mini-quote";
      const wrap = document.createElement("div");
      wrap.className = "tradingview-widget-container";
      card.appendChild(wrap);
      // Lớp link vô hình phủ lên ô: bấm vào đi tới trang chi tiết NỘI BỘ
      // thay vì nhảy sang TradingView (mặc định của widget).
      if (f.slug) {
        const overlay = document.createElement("a");
        overlay.className = "mini-link";
        overlay.href = "/hang-hoa/" + f.slug;
        overlay.setAttribute("aria-label", "Xem chi tiết " + (f.name || ""));
        card.appendChild(overlay);
      }
      grid.appendChild(card);
      const s = document.createElement("script");
      s.async = true;
      s.src = "https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js";
      s.innerHTML = JSON.stringify({
        symbol: f.sym, width: "100%", height: "100%", locale: "vi_VN",
        dateRange: "1M", colorTheme: "dark", isTransparent: true, autosize: true
      });
      wrap.appendChild(s);
    });
  }

  // Tin mới nhất
  const CAT = { metal: "Kim loại", energy: "Năng lượng", agri: "Nông sản", soft: "Nguyên liệu", macro: "Vĩ mô" };
  const CAT_ICON = { metal: "🪙", energy: "🛢️", agri: "🌾", soft: "☕", macro: "🌐" };
  const catIcon = (c) => CAT_ICON[c] || "📦";
  const catKey = (c) => (CAT_ICON[c] ? c : "macro");
  const esc = (s) => String(s || "").replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
  // PHẢI khớp y hệt makeId trong scripts/fetch-news.mjs (link tới trang đọc nội bộ)
  function makeId(s) {
    s = String(s || "");
    let h = 5381;
    for (let i = 0; i < s.length; i++) h = (((h << 5) + h) ^ s.charCodeAt(i)) >>> 0;
    return h.toString(36);
  }
  const readHref = (n) => "/tin-tuc/doc/?id=" + (n.id || makeId(n.link || n.title));
  function fmtWhen(s) {
    if (!s) return "";
    const d = new Date(String(s).replace(" ", "T"));
    if (isNaN(d)) return s;
    const diff = (Date.now() - d.getTime()) / 1000;
    const p = (n) => String(n).padStart(2, "0");
    const abs = `${p(d.getDate())}/${p(d.getMonth() + 1)} ${p(d.getHours())}:${p(d.getMinutes())}`;
    let rel = "";
    if (diff < 60) rel = "vừa xong";
    else if (diff < 3600) rel = Math.floor(diff / 60) + " phút trước";
    else if (diff < 86400) rel = Math.floor(diff / 3600) + " giờ trước";
    else if (diff < 7 * 86400) rel = Math.floor(diff / 86400) + " ngày trước";
    return rel ? `${abs} · ${rel}` : abs;
  }
  const tsOf = (n) => new Date(String(n.published || "").replace(" ", "T")).getTime() || 0;
  // Đọc tin: thử GitHub (tươi nhất) trước, lỗi thì quay về bản tĩnh trong build
  async function loadNewsData() {
    const REMOTE = "https://raw.githubusercontent.com/zz761311-byte/benhanghoa/main/public/data/news.json";
    const LOCAL = "/data/news.json";
    for (const url of [REMOTE, LOCAL]) {
      try { const r = await fetch(url, { cache: "no-store" }); if (r.ok) return await r.json(); } catch (e) {}
    }
    return null;
  }
  const newsHost = document.getElementById("home-news");
  if (newsHost) {
    loadNewsData()
      .then((d) => {
        if (!d) { newsHost.innerHTML = '<div class="empty-note">Chưa tải được tin.</div>'; return; }
        const items = (d.items || []).slice().sort((a, b) => tsOf(b) - tsOf(a)).slice(0, 4);
        if (!items.length) { newsHost.innerHTML = '<div class="empty-note">Chưa có tin.</div>'; return; }
        newsHost.innerHTML = items.map((n) => `
          <article class="news-card">
            <a class="news-card-thumb thumb-${catKey(n.category)}" href="${readHref(n)}" aria-label="${esc(n.title_vi || n.title)}">
              <span class="news-card-icon">${catIcon(n.category)}</span>
              ${n.image ? `<img class="news-card-img" src="${esc(n.image)}" alt="" loading="lazy" onerror="this.remove()">` : ""}
            </a>
            <div class="news-card-body">
              <span class="tag ${n.category || ""}">${CAT[n.category] || "Hàng hóa"}</span>
              <h3><a href="${readHref(n)}">${esc(n.title_vi || n.title)}</a></h3>
              ${n.summary_vi ? `<p class="news-summary clamp-2">${esc(n.summary_vi)}</p>` : ""}
              <div class="news-meta">
                <span>${esc(n.source || "")}</span>
                <span class="news-time">🕒 ${fmtWhen(n.published)}</span>
              </div>
            </div>
          </article>`).join("");
      })
      .catch(() => { newsHost.innerHTML = '<div class="empty-note">Chưa tải được tin.</div>'; });
  }
</script>
