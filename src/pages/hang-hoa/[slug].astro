---
import Layout from "../../layouts/Layout.astro";
import LeadCTA from "../../components/LeadCTA.astro";
import { ALL } from "../../data/commodities.mjs";
import { DETAILS } from "../../data/details.mjs";

export function getStaticPaths() {
  return ALL.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const d = DETAILS[item.slug] || null;

const title = `Giá ${item.name} hôm nay — biểu đồ & thông số hợp đồng | Bến Hàng Hóa`;
const description = `Cập nhật giá ${item.name} real-time, biểu đồ chi tiết, thông số hợp đồng giao dịch và các yếu tố ảnh hưởng giá. ${d ? d.intro.slice(0, 90) : ""}`;

// FAQ schema cho SEO
const faqSchema = d && d.faq ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": d.faq.map((f) => ({
    "@type": "Question", "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
} : null;
---
<Layout page="prices" title={title} description={description}>
  <section class="section">
    <div class="container detail-wrap">
      <nav class="breadcrumb">
        <a href="/">Trang chủ</a> › <a href="/bang-gia">Bảng giá</a> › <span>{item.name}</span>
      </nav>

      <h1>Giá {item.name} hôm nay {item.limited && <span class="lim-badge">dữ liệu hạn chế</span>}</h1>

      <!-- Hộp giá real-time -->
      <div id="symbol-info" class="tradingview-widget-container detail-quote"></div>

      <!-- Biểu đồ lớn -->
      <div class="detail-chart"><div id="adv-chart" class="tradingview-widget-container"></div></div>

      <!-- Thông số hợp đồng -->
      <h2>Thông số hợp đồng</h2>
      {d && d.mxv ? (
        <table class="spec-table">
          <tbody>
            <tr><th>Mã hợp đồng (tham khảo)</th><td>{d.mxv.ma}</td></tr>
            <tr><th>Sở giao dịch gốc</th><td>{d.mxv.san}</td></tr>
            <tr><th>Đơn vị yết giá</th><td>{d.mxv.donVi}</td></tr>
            <tr><th>Độ lớn hợp đồng</th><td>{d.mxv.doLon}</td></tr>
            <tr><th>Bước giá tối thiểu</th><td>{d.mxv.buocGia}</td></tr>
            <tr><th>Tháng đáo hạn</th><td>{d.mxv.thang}</td></tr>
            <tr><th>Giờ giao dịch</th><td>{d.mxv.gio}</td></tr>
            <tr><th>Mức ký quỹ</th><td>Liên hệ tư vấn (thay đổi theo thị trường)</td></tr>
          </tbody>
        </table>
      ) : (
        <p class="spec-note">{d ? d.mxvNote : "Thông số hợp đồng đang được cập nhật. Vui lòng liên hệ để được tư vấn chi tiết."}</p>
      )}
      {d && d.mxv && (
        <p class="spec-disclaimer">⚠️ Thông số mang tính tham khảo — vui lòng xác nhận với bộ phận tư vấn/MXV trước khi giao dịch.</p>
      )}

      <!-- Giới thiệu + yếu tố ảnh hưởng -->
      {d && (
        <>
          <h2>Về {item.name}</h2>
          <p class="detail-intro">{d.intro}</p>
          {d.drivers && (
            <>
              <h3>Yếu tố ảnh hưởng đến giá</h3>
              <ul class="driver-list">
                {d.drivers.map((x) => <li>{x}</li>)}
              </ul>
            </>
          )}
        </>
      )}

      <!-- Thu lead -->
      <LeadCTA item={item.name} />

      <!-- FAQ -->
      {d && d.faq && (
        <>
          <h2>Câu hỏi thường gặp</h2>
          <div class="faq">
            {d.faq.map((f) => (
              <details class="faq-item">
                <summary>{f.q}</summary>
                <p>{f.a}</p>
              </details>
            ))}
          </div>
        </>
      )}

      <p class="back-link"><a href="/bang-gia">← Quay lại bảng giá đầy đủ</a> · <a href="/tin-tuc">Tin tức liên quan →</a></p>
    </div>
  </section>

  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
</Layout>

<style>
  .detail-wrap { max-width: 880px; }
  .breadcrumb { font-size: 13.5px; color: var(--muted); margin-bottom: 10px; }
  .breadcrumb a { color: var(--muted); }
  .breadcrumb a:hover { color: var(--accent); }
  .detail-wrap h1 { font-size: clamp(24px, 3.4vw, 34px); margin: 0 0 16px; }
  .detail-wrap h2 { font-size: 21px; margin: 28px 0 12px; }
  .detail-wrap h3 { font-size: 17px; margin: 18px 0 8px; }
  .detail-quote { min-height: 220px; margin-bottom: 12px; }
  .detail-chart { height: 460px; background: var(--bg-2); border: 1px solid var(--line); border-radius: var(--radius); padding: 8px; }
  .detail-chart .tradingview-widget-container, .detail-chart #adv-chart { height: 100% !important; }
  .spec-table { width: 100%; border-collapse: collapse; background: var(--bg-2); border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; }
  .spec-table th, .spec-table td { padding: 11px 16px; text-align: left; border-bottom: 1px solid var(--line); font-size: 15px; }
  .spec-table th { color: var(--muted); font-weight: 600; width: 42%; }
  .spec-table tr:last-child td, .spec-table tr:last-child th { border-bottom: 0; }
  .spec-note, .spec-disclaimer { color: var(--muted); font-size: 14px; }
  .spec-disclaimer { color: #e3c172; margin-top: 8px; }
  .detail-intro { color: var(--text); font-size: 16px; line-height: 1.7; }
  .driver-list { color: var(--muted); line-height: 1.9; }
  .driver-list li { margin-bottom: 4px; }
  .faq-item { background: var(--bg-2); border: 1px solid var(--line); border-radius: 10px; padding: 12px 16px; margin-bottom: 10px; }
  .faq-item summary { cursor: pointer; font-weight: 600; color: var(--text); }
  .faq-item p { color: var(--muted); margin: 10px 0 0; }
  .back-link { margin-top: 26px; font-size: 14.5px; }
</style>

<script define:vars={{ sym: item.tv }}>
  // Hộp thông tin giá
  const info = document.getElementById("symbol-info");
  if (info) {
    const s = document.createElement("script");
    s.async = true;
    s.src = "https://s3.tradingview.com/external-embedding/embed-widget-symbol-info.js";
    s.innerHTML = JSON.stringify({
      symbol: sym, width: "100%", locale: "vi_VN", colorTheme: "dark", isTransparent: true
    });
    info.appendChild(s);
  }
  // Biểu đồ lớn
  const chart = document.getElementById("adv-chart");
  if (chart) {
    const s = document.createElement("script");
    s.async = true;
    s.src = "https://s3.tradingview.com/external-embedding/embed-widget-advanced-chart.js";
    s.innerHTML = JSON.stringify({
      symbol: sym, autosize: true, interval: "D", timezone: "Asia/Ho_Chi_Minh",
      theme: "dark", style: "1", locale: "vi_VN", hide_side_toolbar: false,
      allow_symbol_change: false, calendar: false
    });
    chart.appendChild(s);
  }
</script>
