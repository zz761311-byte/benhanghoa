---
import Layout from "../../layouts/Layout.astro";
import LeadCTA from "../../components/LeadCTA.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// JSON-LD Article → Google hiển thị ngày đăng, ảnh, brand trong kết quả tìm kiếm.
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  datePublished: post.data.date.toISOString(),
  image: new URL(post.data.image || "/assets/img/logo-badge.png", Astro.site).href,
  description: post.data.summary || post.data.title,
  inLanguage: "vi-VN",
  mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).href,
  author: { "@type": "Organization", name: "Bến Hàng Hóa" },
  publisher: {
    "@type": "Organization",
    name: "Bến Hàng Hóa",
    logo: { "@type": "ImageObject", url: new URL("/assets/img/logo-badge.png", Astro.site).href }
  }
};
---
<Layout page="analysis" title={`${post.data.title} — Bến Hàng Hóa`} description={post.data.summary || post.data.title} image={post.data.image || ""}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <section class="section">
    <div class="container" style="max-width:760px">
      <nav class="breadcrumb">
        <a href="/">Trang chủ</a> › <a href="/phan-tich">Phân tích</a> › <span>{post.data.title}</span>
      </nav>
      <h1>{post.data.title}</h1>
      <div class="post-meta">{post.data.date.toLocaleDateString("vi-VN")}</div>
      {post.data.image && <img class="post-cover" src={post.data.image} alt={post.data.title} />}
      <article class="post-body"><Content /></article>

      <LeadCTA item="giao dịch hàng hóa" />

      <p class="back-link"><a href="/phan-tich">← Quay lại danh sách bài viết</a></p>
    </div>
  </section>
</Layout>

<style>
  .breadcrumb { font-size: 13.5px; color: var(--muted); margin-bottom: 10px; }
  .breadcrumb a { color: var(--muted); }
  .breadcrumb a:hover { color: var(--accent); }
  h1 { font-size: clamp(24px, 3.4vw, 34px); margin: 0 0 6px; }
  .post-meta { color: var(--muted); font-size: 14px; margin-bottom: 18px; }
  .post-cover { width: 100%; border-radius: var(--radius); margin-bottom: 18px; }
  .post-body { color: var(--text); font-size: 16.5px; line-height: 1.75; }
  .post-body :global(h2) { font-size: 22px; margin: 26px 0 10px; }
  .post-body :global(h3) { font-size: 18px; margin: 20px 0 8px; }
  .post-body :global(p) { margin: 0 0 14px; color: var(--text); }
  .post-body :global(ul) { color: var(--muted); line-height: 1.9; }
  .post-body :global(blockquote) {
    border-left: 3px solid var(--accent); padding: 4px 16px; margin: 16px 0;
    color: var(--muted); background: var(--bg-2); border-radius: 0 8px 8px 0;
  }
  .post-body :global(a) { color: var(--accent-2); }
  .back-link { margin-top: 28px; font-size: 14.5px; }
</style>
