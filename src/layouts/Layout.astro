---
import { CONTACT } from "../data/contact.mjs";
const {
  title = "Bến Hàng Hóa — Giá hàng hóa & tin tức cho người Việt",
  description = "Cập nhật giá hàng hóa thế giới (năng lượng, nông sản, kim loại) và tin tức ảnh hưởng đến giá, bằng tiếng Việt.",
  page = "",
  noindex = false
} = Astro.props;

// URL tuyệt đối cho thẻ chia sẻ (Zalo/Facebook bỏ qua đường dẫn tương đối).
const ogImage = new URL("/assets/img/logo-badge.png", Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

const links = [
  { key: "home",     href: "/",           label: "Trang chủ" },
  { key: "prices",   href: "/bang-gia",   label: "Bảng giá" },
  { key: "news",     href: "/tin-tuc",    label: "Tin tức" },
  { key: "analysis", href: "/phan-tich",  label: "Phân tích" },
  { key: "knowledge", href: "/kien-thuc", label: "Kiến thức" },
  { key: "about",    href: "/gioi-thieu", label: "Giới thiệu" }
];
---
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, follow" />}
  <meta property="og:site_name" content="Bến Hàng Hóa" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="vi_VN" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg" />
  <link rel="stylesheet" href="/assets/css/style.css" />
</head>
<body data-page={page}>
  <header class="site-header">
    <div class="container nav">
      <a class="brand" href="/">
        <img class="logo-img" src="/assets/img/logo-icon.png" alt="Bến Hàng Hóa" />
        <span>BẾN <b>HÀNG HÓA</b></span>
      </a>
      <button class="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="nav-links">☰</button>
      <nav class="nav-links" id="nav-links">
        {links.map((l) => (
          <a href={l.href} class={l.key === page ? "active" : ""}>{l.label}</a>
        ))}
      </nav>
    </div>
  </header>

  <slot />

  <footer class="site-footer">
    <div class="container">
      <div>
        <span style="display:inline-flex;align-items:center;gap:8px">
          <img src="/assets/img/logo-icon.png" alt="" style="width:24px;height:24px;border-radius:50%;background:#2e5a3c" />
          <strong style="color:var(--text)">Bến Hàng Hóa</strong>
        </span> — Giá hàng hóa & tin tức cho người Việt.<br />
        Dữ liệu giá từ TradingView. Chỉ mang tính tham khảo.<br />
        <span style="color:var(--muted);font-size:12.5px">Bến Hàng Hóa là website thông tin do cá nhân/cộng tác viên vận hành — KHÔNG phải Sở Giao dịch Hàng hóa Việt Nam (MXV) và KHÔNG phải công ty Thành viên; chỉ hỗ trợ kết nối mở tài khoản qua Thành viên Kinh doanh được MXV cấp phép.</span>
        <span style="display:block;margin-top:8px;color:#d9a441;font-size:12.5px;line-height:1.5">⚠️ Giao dịch hàng hóa phái sinh sử dụng đòn bẩy, rủi ro cao, có thể mất toàn bộ vốn ký quỹ. Nội dung trên website chỉ mang tính tham khảo, KHÔNG phải khuyến nghị đầu tư.</span>
      </div>
      <div>
        © 2026 Bến Hàng Hóa ·
        <a href="/bang-gia">Bảng giá</a> ·
        <a href="/tin-tuc">Tin tức</a> ·
        <a href={CONTACT.facebookUrl} target="_blank" rel="noopener">📘 Fanpage Facebook</a>
      </div>
    </div>
  </footer>

  <!-- Nút nổi liên hệ — hiện ở mọi trang, góc dưới phải -->
  <div class="float-contact">
    <a class="fc-btn fc-zalo" href={CONTACT.zaloUrl} target="_blank" rel="noopener" aria-label="Chat Zalo tư vấn">
      <span class="fc-icon">💬</span><span class="fc-label">Chat Zalo</span>
    </a>
    <a class="fc-btn fc-phone" href={`tel:${CONTACT.hotlineTel}`} aria-label="Gọi hotline tư vấn">
      <span class="fc-icon">📞</span><span class="fc-label">{CONTACT.hotline}</span>
    </a>
    <a class="fc-btn fc-facebook" href={CONTACT.facebookUrl} target="_blank" rel="noopener" aria-label="Theo dõi Fanpage Facebook">
      <span class="fc-icon" aria-hidden="true"><svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5 3.66 9.15 8.44 9.94v-7.03H7.9v-2.9h2.54V9.85c0-2.51 1.49-3.9 3.78-3.9 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.44 2.9h-2.34V22c4.78-.79 8.44-4.94 8.44-9.94z"/></svg></span><span class="fc-label">Fanpage</span>
    </a>
  </div>

  <script>
    const toggle = document.querySelector(".nav-toggle");
    const menu = document.querySelector(".nav-links");
    if (toggle && menu) {
      toggle.addEventListener("click", () => {
        const open = menu.classList.toggle("open");
        toggle.setAttribute("aria-expanded", open ? "true" : "false");
      });
    }
  </script>
</body>
</html>
